{
  "info": {
    "name": "Games5150 TIF",
    "description": "Postman Collection para el Trabajo Integrador Final de Desarrollo Full-Stack",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Autenticación",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Juan Perez\",\n  \"email\": \"juan@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{API_URL}}/auth/register",
              "host": [
                "{{API_URL}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData && jsonData.data && jsonData.data.access_token) {",
                  "    pm.environment.set(\"TOKEN\", jsonData.data.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@games5150.online\",\n  \"password\": \"Admin1234!\"\n}"
            },
            "url": {
              "raw": "{{API_URL}}/auth/login",
              "host": [
                "{{API_URL}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{API_URL}}/auth/me",
              "host": [
                "{{API_URL}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. Juegos (CRUD)",
      "item": [
        {
          "name": "Obtener todos los juegos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{API_URL}}/games",
              "host": [
                "{{API_URL}}"
              ],
              "path": [
                "games"
              ]
            }
          }
        },
        {
          "name": "Obtener juego por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{API_URL}}/games/1",
              "host": [
                "{{API_URL}}"
              ],
              "path": [
                "games",
                "1"
              ]
            }
          }
        },
        {
          "name": "Crear Juego (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Nuevo Juego Test\",\n  \"developer\": \"Test Dev\",\n  \"release_year\": 2024,\n  \"genre_id\": 1,\n  \"description\": \"Una descripcion genial.\",\n  \"platform\": \"PC\"\n}"
            },
            "url": {
              "raw": "{{API_URL}}/games",
              "host": [
                "{{API_URL}}"
              ],
              "path": [
                "games"
              ]
            }
          }
        },
        {
          "name": "Eliminar Juego (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{API_URL}}/games/1",
              "host": [
                "{{API_URL}}"
              ],
              "path": [
                "games",
                "1"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. Géneros",
      "item": [
        {
          "name": "Obtener Géneros",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{API_URL}}/genres",
              "host": [
                "{{API_URL}}"
              ],
              "path": [
                "genres"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "4. Wishlist",
      "item": [
        {
          "name": "Mi Wishlist",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{API_URL}}/wishlist",
              "host": [
                "{{API_URL}}"
              ],
              "path": [
                "wishlist"
              ]
            }
          }
        },
        {
          "name": "Agregar a Wishlist",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"game_id\": 2\n}"
            },
            "url": {
              "raw": "{{API_URL}}/wishlist",
              "host": [
                "{{API_URL}}"
              ],
              "path": [
                "wishlist"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "API_URL",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "TOKEN",
      "value": "",
      "type": "string"
    }
  ]
}
